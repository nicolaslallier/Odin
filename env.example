# Odin Development Environment Configuration
# Copy this file to .env and adjust values as needed

# PostgreSQL Configuration
POSTGRES_USER=odin
POSTGRES_PASSWORD=odin_dev_password
POSTGRES_DB=odin_db

# n8n Configuration
N8N_DB_NAME=n8n
N8N_USER=admin
N8N_PASSWORD=admin
N8N_HOST=localhost

# RabbitMQ Configuration
RABBITMQ_USER=odin
RABBITMQ_PASSWORD=odin_dev_password

# HashiCorp Vault Configuration
VAULT_ROOT_TOKEN=dev-root-token

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Web Application Configuration
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_RELOAD=true
WEB_LOG_LEVEL=info

# Celery Worker Configuration
CELERY_BROKER_URL=amqp://odin:odin_dev_password@rabbitmq:5672//
CELERY_RESULT_BACKEND=db+postgresql://odin:odin_dev_password@postgresql:5432/odin_db
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=3600
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# Flower Configuration
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:admin

# API Service Configuration
API_HOST=0.0.0.0
API_PORT=8001
API_RELOAD=true
API_LOG_LEVEL=info

# Database Connection (for API)
# Note: Use standard postgresql:// format - it will be automatically converted to async driver
# The API will use asyncpg driver: postgresql+asyncpg://
POSTGRES_DSn=postgresql://odin:odin_dev_password@postgresql:5432/odin_db

# MinIO Configuration (for API)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# RabbitMQ Configuration (for API)
RABBITMQ_URL=amqp://odin:odin_dev_password@rabbitmq:5672/

# Vault Configuration (for API)
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=dev-root-token

# Ollama Configuration (for API)
OLLAMA_BASE_URL=http://ollama:11434

# Image Analysis Configuration (v1.3.0)
# Default vision model for image analysis
VISION_MODEL_DEFAULT=llava:latest
# MinIO bucket for image storage
IMAGE_BUCKET=images
# Maximum image size in megabytes
MAX_IMAGE_SIZE_MB=10

# Centralized Logging Configuration (v1.2.0)
# How many days to retain logs before automatic cleanup
LOG_RETENTION_DAYS=30

# Database log handler buffer settings
# Number of log records to buffer before flushing to database
LOG_BUFFER_SIZE=100

# Maximum seconds to wait before flushing buffer (even if not full)
LOG_BUFFER_TIMEOUT=5.0

# Minimum log level to store in database (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL_DB_MIN=INFO

