# Odin Development Environment Configuration
# Copy this file to .env and adjust values as needed

# PostgreSQL Configuration
POSTGRES_USER=odin
POSTGRES_PASSWORD=odin_dev_password
POSTGRES_DB=odin_db

# n8n Configuration
N8N_DB_NAME=n8n
N8N_USER=admin
N8N_PASSWORD=admin
N8N_HOST=localhost

# RabbitMQ Configuration
RABBITMQ_USER=odin
RABBITMQ_PASSWORD=odin_dev_password

# HashiCorp Vault Configuration
VAULT_ROOT_TOKEN=dev-root-token

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Web Application Configuration
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_RELOAD=true
WEB_LOG_LEVEL=info

